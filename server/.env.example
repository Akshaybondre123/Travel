PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/travel-itinerary
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_URL=http://localhost:5173

GEMINI_API_KEY=your-gemini-api-key

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Vercel: set Root Directory to "server" and add all vars above in Project Settings.
# S3 is required on Vercel (no local uploads folder). Use Render/Railway for long-running dev server.
